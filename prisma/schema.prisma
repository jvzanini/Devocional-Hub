generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Usuários ────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  password        String?   // Nullable: convite pendente não tem senha ainda
  name            String
  role            UserRole  @default(MEMBER)
  church          String    @default("")
  team            String    @default("")
  subTeam         String    @default("")
  photoUrl        String?
  inviteToken     String?   @unique
  inviteExpiresAt DateTime?
  createdAt       DateTime  @default(now())
}

enum UserRole {
  ADMIN
  MEMBER
}

// ─── Sessões (devocionais) ───────────────────────────────────────────────

model Session {
  id              String         @id @default(cuid())
  date            DateTime
  zoomMeetingId   String
  zoomRecordingId String
  zoomUuid        String         @default("")
  chapterRef      String         @default("")
  summary         String         @default("") @db.Text
  status          PipelineStatus @default(PENDING)
  errorMessage    String?
  documents       Document[]
  participants    Participant[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Participant {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  joinTime  DateTime
  leaveTime DateTime
  duration  Int      // segundos
}

model Document {
  id          String   @id @default(cuid())
  sessionId   String
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type        DocType
  fileName    String
  storagePath String
  fileSize    Int?
  createdAt   DateTime @default(now())
}

enum DocType {
  TRANSCRIPT_RAW
  TRANSCRIPT_CLEAN
  BIBLE_TEXT
  INFOGRAPHIC
  SLIDES
}

enum PipelineStatus {
  PENDING
  RUNNING
  COMPLETED
  ERROR
}

// ─── Webhooks ────────────────────────────────────────────────────────────

model Webhook {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  secret    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ─── Configurações ───────────────────────────────────────────────────────

model AppSetting {
  key   String @id
  value String
}
