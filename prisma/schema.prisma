generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Usuários ────────────────────────────────────────────────────────────

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  password        String?
  name            String
  role            UserRole         @default(MEMBER)
  church          String           @default("")
  team            String           @default("")
  subTeam         String           @default("")
  photoUrl        String?
  active          Boolean          @default(true)
  inviteToken     String?          @unique
  inviteExpiresAt DateTime?
  createdAt       DateTime         @default(now())
  zoomIdentifiers ZoomIdentifier[]
  attendances     Attendance[]
}

enum UserRole {
  ADMIN
  MEMBER
}

model ZoomIdentifier {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  value     String
  type      ZoomIdType
  locked    Boolean    @default(false)
  createdAt DateTime   @default(now())

  @@unique([userId, value])
}

enum ZoomIdType {
  EMAIL
  USERNAME
}

// ─── Sessões (devocionais) ───────────────────────────────────────────────

model Session {
  id              String         @id @default(cuid())
  date            DateTime
  zoomMeetingId   String
  zoomRecordingId String
  zoomUuid        String         @default("")
  chapterRef      String         @default("")
  summary         String         @default("") @db.Text
  status          PipelineStatus @default(PENDING)
  errorMessage    String?
  documents       Document[]
  participants    Participant[]
  attendances     Attendance[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Participant {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  joinTime  DateTime
  leaveTime DateTime
  duration  Int
}

model Document {
  id          String   @id @default(cuid())
  sessionId   String
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type        DocType
  fileName    String
  storagePath String
  fileSize    Int?
  createdAt   DateTime @default(now())
}

enum DocType {
  TRANSCRIPT_RAW
  TRANSCRIPT_CLEAN
  BIBLE_TEXT
  INFOGRAPHIC
  SLIDES
}

enum PipelineStatus {
  PENDING
  RUNNING
  COMPLETED
  ERROR
}

// ─── Presença ────────────────────────────────────────────────────────────

model Attendance {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  joinTime  DateTime
  leaveTime DateTime
  duration  Int
  createdAt DateTime @default(now())

  @@unique([userId, sessionId])
}

// ─── Plano de Leitura ───────────────────────────────────────────────────

model ReadingPlan {
  id             String            @id @default(cuid())
  bookName       String
  bookCode       String
  bookOrder      Int
  chaptersPerDay Int
  totalChapters  Int
  startDate      DateTime
  endDate        DateTime
  status         ReadingPlanStatus @default(UPCOMING)
  imageUrl       String?
  days           ReadingPlanDay[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

enum ReadingPlanStatus {
  UPCOMING
  IN_PROGRESS
  COMPLETED
}

model ReadingPlanDay {
  id             String      @id @default(cuid())
  planId         String
  plan           ReadingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  date           DateTime
  chapters       String
  completed      Boolean     @default(false)
  logNote        String?
  actualChapters String?

  @@unique([planId, date])
}

// ─── Webhooks ────────────────────────────────────────────────────────────

model Webhook {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  secret    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ─── Configurações ───────────────────────────────────────────────────────

model AppSetting {
  key   String @id
  value String
}
